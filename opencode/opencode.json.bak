{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM",
      "options": {
        "baseURL": "{env:LITELLM_ENDPOINT}",
        "apiKey": "{env:LITELLM_API_KEY}"
      },
      "models": {
        "gpt-4-1": {
          "name": "GPT-4"
        },
        "claude-3-5-sonnet-20241022": {
          "name": "Claude 3.5 Sonnet"
        },
        "gemini-2.5-pro": {
          "name": "gemini-2.5-pro"
        }
      }
    }
  },
  "plugin": [
    "oh-my-opencode"
  ]
}
